{
  "dashboard": {
    "id": null,
    "uid": "lab8-monitoring",
    "title": "Lab 8 Monitoring",
    "timezone": "browser",
    "schemaVersion": 39,
    "version": 0,
    "refresh": "5s",
    "panels": [
      {
        "id": 1,
        "title": "Total Successful Requests",
        "type": "timeseries",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus-lab8"
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 0
        },
        "targets": [
          {
            "refId": "A",
            "expr": "request_count_total{http_status=\"200\"}",
            "legendFormat": "status 200"
          }
        ]
      },
      {
        "id": 2,
        "title": "Total Recommendation Requests Over Time",
        "type": "timeseries",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus-lab8"
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 0
        },
        "targets": [
          {
            "refId": "A",
            "expr": "sum(rate(request_count_total[5m]))",
            "legendFormat": "requests/sec"
          }
        ]
      },
      {
        "id": 3,
        "title": "Node CPU Usage (system mode)",
        "type": "timeseries",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus-lab8"
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 8
        },
        "targets": [
          {
            "refId": "A",
            "expr": "sum(rate(node_cpu_seconds_total{mode=\"system\"}[5m]))",
            "legendFormat": "system cpu"
          }
        ]
      },
      {
        "id": 4,
        "title": "95th Percentile Request Latency",
        "type": "timeseries",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus-lab8"
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 8
        },
        "targets": [
          {
            "refId": "A",
            "expr": "histogram_quantile(0.95, sum(rate(request_latency_seconds_bucket[5m])) by (le))",
            "legendFormat": "p95 latency"
          }
        ]
      },
      {
        "id": 5,
        "title": "Average Request Latency",
        "type": "timeseries",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus-lab8"
        },
        "gridPos": {
          "h": 8,
          "w": 24,
          "x": 0,
          "y": 16
        },
        "targets": [
          {
            "refId": "A",
            "expr": "rate(request_latency_seconds_sum[5m]) / rate(request_latency_seconds_count[5m])",
            "legendFormat": "avg latency"
          }
        ]
      }
    ]
  },
  "folderId": 0,
  "overwrite": true
}
